# Public build/runtime URL metadata. Required in production and safe to expose.
NEXT_PUBLIC_SITE_URL=http://localhost:3010

# Supported by app code, but keep empty until legal/cookie consent flow and owner approval.
# If activated later, set a numeric Yandex Metrica counter ID before build/deploy.
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# Server-only webmaster verification. Set only when real codes exist.
GOOGLE_SITE_VERIFICATION=
YANDEX_WEBMASTER_VERIFICATION=

# Server-only lead API abuse protection. Required in production.
LEADS_ALLOWED_ORIGINS=https://kuhni-kit.ru,https://www.kuhni-kit.ru

# Server-only Directus mode.
# Recommended as durable production lead storage. Leave empty only when local fallback is acceptable.
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=

# Directus Docker Compose
DIRECTUS_PORT=8055
DIRECTUS_PUBLIC_URL=http://localhost:8055
DIRECTUS_CORS_ORIGIN=http://localhost:3000,http://localhost:3010
DIRECTUS_KEY=replace-with-random-key
DIRECTUS_SECRET=replace-with-random-secret
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me
DIRECTUS_DB_DATABASE=directus
DIRECTUS_DB_USER=directus
DIRECTUS_DB_PASSWORD=change-me

# Server-only optional notifications. These are not durable lead storage.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# Optional advanced SMTP settings supported by the app.
# SMTP_HELO_NAME=kuhni-kit.ru
# SMTP_REJECT_UNAUTHORIZED=true
